# Maintainer: Corey De Lasaux <cordelster@gmail.com>
pkgname=s6-openrc-compat
pkgver=0.3.0
pkgrel=0
pkgdesc="OpenRC compatibility layer for s6-overlay"
url="https://github.com/jambox-it/s6-openrc-compat"
arch="all"
license="GPL-3.0-or-later"
depends="s6"
makedepends="make sed shellcheck"
subpackages="s6-openrc-compat-hassio:hassio"
source="https://github.com/jambox-it/$pkgname/releases/download/v$pkgver/$pkgname-$pkgver.tar.gz"
builddir="$srcdir/$pkgname-$pkgver"

_bindir=/usr/bin
_s6_run_dir=/run/s6/legacy-services

prepare() {
	default_prepare
}

build() {
	make BINDIR="$_bindir" S6_RUN_DIR="$_s6_run_dir"
}

check() {
	make check BINDIR="$_bindir" S6_RUN_DIR="$_s6_run_dir"
}

package() {
	make install \
		DESTDIR="$pkgdir" \
		PREFIX=/usr \
		BINDIR="$_bindir" \
		SYSCONFDIR=/etc \
		S6_RUN_DIR="$_s6_run_dir"
}

hassio() {
	pkgdesc="OpenRC compatibility layer for s6-overlay (Home Assistant addon, no s6 dep)"
	depends=""
	replaces="$pkgname"
	provides="$pkgname=$pkgver-r$pkgrel"

	# All binaries — HA base image provides s6, no Alpine s6 APK needed
	install -d "$subpkgdir/usr/bin"
	install -m 755 "$pkgdir/usr/bin/rc-service" "$subpkgdir/usr/bin/rc-service"
	install -m 755 "$pkgdir/usr/bin/rc-status" "$subpkgdir/usr/bin/rc-status"
	install -m 755 "$pkgdir/usr/bin/rc-update" "$subpkgdir/usr/bin/rc-update"
	install -m 755 "$pkgdir/usr/bin/init-openrc-compat.sh" "$subpkgdir/usr/bin/init-openrc-compat.sh"

	# cont-init wires up /etc/init.d/ service stubs automatically at container start
	install -d "$subpkgdir/etc/cont-init.d"
	install -m 755 "$pkgdir/usr/bin/init-openrc-compat.sh" \
		"$subpkgdir/etc/cont-init.d/10-s6-openrc-compat.sh"
}

sha512sums="
7dc5d4ec6ed3b4a84dc08754a31447effe3fea544500f2812edd993ec13114138fce283e1051e07519b80a872b427e87122e592fc00f7b0df22796711e6cd642  s6-openrc-compat-0.3.0.tar.gz
"
